# Regtest harness — pinned images/versions and settings.
#
# These RPC credentials are for an isolated, localhost-only regtest network.
# They are intentionally public and must NEVER be reused anywhere real.

COMPOSE_PROJECT_NAME=btcdwatch-regtest

# Bitcoin Core image — mines and generates the transaction traffic. No
# official Core image exists, so this is a pinned community build. After the
# first `docker pull`, pin it by @sha256 digest for full reproducibility.
BITCOIND_IMAGE=lncm/bitcoind:v27.0

# btcd (the node under test) is built from source at this tag on golang:*.
BTCD_VERSION=v0.26.0
GO_VERSION=1.25

# Shared regtest RPC credentials (btcd + Bitcoin Core).
RPC_USER=regtest
RPC_PASS=regtest

# btcd's RPC port, published to the host loopback for btcdwatchd.
BTCD_RPC_PORT=18334

# Simulation cadence (seconds). Lower = livelier demo; higher = calmer.
BLOCK_INTERVAL=15
TX_INTERVAL=4
